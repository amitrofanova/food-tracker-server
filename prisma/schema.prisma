// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  password       String
  createdAt      DateTime         @default(now())
  entries        DiaryEntry[]
  customProducts CustomProduct[]
  recipes        Recipe[]
  calorieBudget  Int?
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model Product {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  calories  Float    // ккал на 100 г
  protein   Float    // г на 100 г
  fat       Float    // г на 100 г
  carbs     Float    // г на 100 г
  entries   DiaryEntry[]
}

model DiaryEntry {
  id         Int       @id @default(autoincrement())
  date       DateTime
  weight     Float
  mealType   MealType
  userId     Int
  productId  BigInt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime  @default(now())
}

model CustomProduct {
  id        String   @id
  name      String
  calories  Float
  protein   Float
  fat       Float
  carbs     Float
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Recipe {
  id          String             @id
  name        String
  totalWeight Float
  calories    Float
  protein     Float
  fat         Float
  carbs       Float
  userId      Int
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]
  createdAt   DateTime           @default(now())
}

model RecipeIngredient {
  id          Int    @id @default(autoincrement())
  recipeId    String
  productId   String
  productName String
  weight      Float
  calories    Float
  protein     Float
  fat         Float
  carbs       Float
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}